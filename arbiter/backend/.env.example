# ═══════════════════════════════════════════════════════════════
# Arbiter Backend — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Google Gemini (AI Core) ─────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-pro-exp

# ── Google Cloud Platform ───────────────────────────────────────
# Your GCP project ID (not the display name)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1
GCS_BUCKET_NAME=arbiter-documents
VERTEX_AI_SEARCH_ID=

# ── Firebase ────────────────────────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to downloaded service account JSON (leave empty to use Application Default Credentials)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Razorpay ────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_ keys for development/staging
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── App Settings ────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]

# ── Pricing ─────────────────────────────────────────────────────
# Amounts in paise (1 INR = 100 paise)
DOC_PRICE_PAISE=29900
MONTHLY_PRICE_PAISE=79900

# ── Sentry (Error Monitoring) ───────────────────────────────────
# Get from: https://sentry.io (free tier available)
# Leave empty to disable
SENTRY_DSN=

# ── Admin API ───────────────────────────────────────────────────
# X-Admin-Key header required for /api/admin/* endpoints
# Generate a strong random string for production
ADMIN_SECRET_KEY=change-me-generate-a-strong-random-key

# ── Backup Storage ──────────────────────────────────────────────
BACKUP_BUCKET_NAME=arbiter-backups

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=500

# ── Multi-Country ───────────────────────────────────────────────
DEFAULT_COUNTRY_CODE=IN
PROMPT_ENHANCEMENT_ENABLED=true

# ── Weekly Content Refresh ──────────────────────────────────────
WEEKLY_UPDATE_ENABLED=true
