# =======================================================================
#  Arbiter Backend - Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# =======================================================================

# -- Google Gemini -------------------------------------------------------
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-pro-exp

# -- Google Cloud --------------------------------------------------------
# Your GCP project ID (e.g. arbiter-prod-2026)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1
GCS_BUCKET_NAME=arbiter-documents

# Vertex AI Search data store ID (leave empty to skip law search)
VERTEX_AI_SEARCH_ID=

# -- Firebase ------------------------------------------------------------
# Found in Firebase Console -> Project Settings -> General
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to service account JSON (leave empty to use Application Default Credentials)
# Download from: Firebase Console -> Project Settings -> Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=

# -- Razorpay ------------------------------------------------------------
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# -- App -----------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# Pricing in paise (1 INR = 100 paise)
DOC_PRICE_PAISE=29900
MONTHLY_PRICE_PAISE=79900
