// ─────────────────────────────────────────────────────────────────────────────
// Arbiter — Firestore Security Rules
//
// Principles:
//   1. Users can only read/write their OWN data
//   2. Documents require payment before full read
//   3. All writes require authentication
//   4. No user can modify another user's data
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Is the request from an authenticated user?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Does the document belong to the requesting user?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Is the requesting user an admin?
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Cases collection ──────────────────────────────────────────────────────
    match /cases/{caseId} {
      // Read: only the case owner or admin
      allow read: if isOwner(resource.data.user_id) || isAdmin();

      // Create: authenticated user creating their own case
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;

      // Update: only the case owner (cannot change user_id)
      allow update: if isOwner(resource.data.user_id) &&
        request.resource.data.user_id == resource.data.user_id;

      // Delete: only admin (soft delete preferred)
      allow delete: if isAdmin();
    }

    // ── Documents collection ──────────────────────────────────────────────────
    match /documents/{documentId} {
      // Read: owner can always read metadata; full content only if paid (or admin)
      allow read: if isOwner(resource.data.user_id) || isAdmin();

      // Create: authenticated user creating their own document
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;

      // Update: owner can update (payment status updates, etc.) — cannot change user_id
      allow update: if isOwner(resource.data.user_id) &&
        request.resource.data.user_id == resource.data.user_id;

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isOwner(userId);

      // Admin can read all profiles
      allow read: if isAdmin();
    }

    // ── Reminders collection ─────────────────────────────────────────────────
    match /reminders/{reminderId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.user_id == request.auth.uid) &&
        request.resource.data.user_id == request.auth.uid;

      allow read: if isAdmin();
    }

    // ── Admins collection ────────────────────────────────────────────────────
    // Only admins can read the admins list (for isAdmin() function above)
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
